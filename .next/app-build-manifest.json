      "static/chunks/app/(app)/today/page.js"
    ],
    "/(app)/habits/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/habits/page.js"
    ],
    "/api/habits/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/habits/route.js"
    ]
  }
